# Auth — never commit regardless of location
auth.json
**/auth.json

# Profiles - exclude session data
profiles/**/.env
profiles/**/sessions/

# Session history
agent/sessions/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak
*.bak-*

# Windows null-device redirect artifacts
nul
NUL

# Node
node_modules/

# Vendored binaries
agent/bin/
**/*.exe

# Claude Code and OMC/OMX runtime state (local only)
.claude/
.omc/
agent/.claude/
agent/.omx/

# Diagnostic/investigation dumps
root-artifacts/

# Imported skills (large external package, not owned here)
agent/skills/pk-skills1-imported/
